# Your Follow Up Boss API Key
# Get it from: FUB Settings > API > Copy your API key
FUB_API_KEY=your_api_key_here

# Safe Mode (recommended for remote deployments) -- disables all delete tools.
# Set to "true" to enable, "false" for full access
FUB_SAFE_MODE=true

# Transport mode:
#   unset or "stdio"  -> Local stdio (Claude Desktop / Cowork default). No auth.
#   "http"            -> Remote HTTP/SSE server (Railway, Fly, etc). Requires MCP_BEARER_TOKEN.
MCP_TRANSPORT=stdio

# Only required when MCP_TRANSPORT=http. Generate a strong random secret (32+ chars).
# Example generators:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Claude's custom connector will send this as: Authorization: Bearer <token>
MCP_BEARER_TOKEN=

# Port for HTTP mode. Railway sets this automatically; leave blank in production.
PORT=3000
